{
  "name": "@chaomingd/docs",
  "version": "0.0.0",
  "private": true,
  "description": "A react library developed with dumi",
  "license": "MIT",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [],
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "create": "node scripts/run-create-template.js",
    "build:all": "pnpm run --if-present --recursive --filter \"@chaomingd/*\" build",
    "build": "pnpm run --if-present --recursive --filter \"...[origin/master]\" build",
    "build:watch": "father dev",
    "dev": "dumi dev",
    "docs:build": "dumi build",
    "docs:preview": "dumi preview",
    "doctor": "father doctor",
    "eslint": "eslint . --fix",
    "lint": "pnpm run \"/^lint:.+/\"",
    "test": "vitest",
    "lint:eslint": "eslint --ext .ts,.tsx .",
    "prepare": "husky install && dumi setup",
    "prepublishOnly": "father doctor && npm run build",
    "change:version": "pnpm changeset && changeset version && pnpm run build && pnpm run lint",
    "release": "npm run login:repository && sh scripts/deploy.sh",
    "login:repository": "sh scripts/pnpm-login.sh",
    "start": "npm run dev",
    "test:ci": "cross-env LIB_DIR=normal vitest --coverage"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{md,json}": [
      "prettier --write --no-error-on-unmatched-pattern"
    ],
    "*.{css,less}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --parser=typescript --write"
    ]
  },
  "dependencies": {
    "ahooks": "^3.8.1",
    "antd": "^5.21.2",
    "axios": ">=1.4.0",
    "immer": "^10.1.1"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.5.2",
    "@changesets/changelog-git": "^0.2.0",
    "@changesets/cli": "^2.27.9",
    "@commitlint/cli": "^17.8.1",
    "@commitlint/config-conventional": "^17.8.1",
    "@emotion/react": "^11.14.0",
    "@chaomingd/design": "workspace:*",
    "@chaomingd/hooks": "workspace:*",
    "@chaomingd/store": "workspace:*",
    "@chaomingd/utils": "workspace:*",
    "@testing-library/react": "^16.0.1",
    "@types/katex": "^0.16.7",
    "@types/lodash": "^4.17.13",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/use-sync-external-store": "^0.0.6",
    "@umijs/fabric": "^4.0.1",
    "@vitest/coverage-v8": "^1.6.0",
    "antd-style": "^3.7.0",
    "antd-token-previewer-laf": "^0.0.3",
    "babel-plugin-inline-react-svg": "^2.0.2",
    "babel-plugin-react-inline-svg-unique-id": "^1.5.0",
    "classnames": "^2.5.1",
    "cross-env": "^7.0.3",
    "dumi": "~2.2.17",
    "dumi-theme-antd-laf": "^0.0.1",
    "eslint": "^8.57.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "father": "^4.5.0",
    "husky": "^8.0.3",
    "jsdom": "^24.1.3",
    "lint-staged": "^13.3.0",
    "lodash": "^4.17.21",
    "lodash.camelcase": "^4.3.0",
    "prettier": "^2.8.8",
    "prettier-plugin-organize-imports": "^3.2.4",
    "prettier-plugin-packagejson": "^2.5.3",
    "rc-table": "^7.48.1",
    "rc-tabs": "^15.4.0",
    "rc-util": "^5.43.0",
    "react": "^18.3.1",
    "react-copy-to-clipboard": "^5.1.0",
    "react-dom": "^18.3.1",
    "react-intl": "^7.0.4",
    "stylelint": "^14.16.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "axios": ">=1.4.0",
    "react": ">=16.9.0",
    "react-dom": ">=16.9.0"
  },
  "engines": {
    "node": ">=18"
  },
  "authors": []
}
