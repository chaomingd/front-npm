{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@emotion/react",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": "../",
    "paths": {
      "@@/*": [".dumi/tmp/*"],
      "@chaomingd/ui": ["packages/ui/src/index.ts"],
      "@chaomingd/ui/es/*": ["packages/ui/src/*"],
      "dumi/theme/*": [".dumi/theme/*"]
    }
  },
  "include": ["./**/*", "../site/theme/template/Content"]
}
