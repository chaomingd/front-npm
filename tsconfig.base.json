{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["esnext", "es6", "dom" ],
    "strict": true,
    "esModuleInterop": true,
    "baseUrl": "./",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "declaration": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@ant-design/cssinjs": ["node_modules/@ant-design/cssinjs"],
      "@@/*": [".dumi/tmp/*"],
      "@chaomingd/design": ["./packages/design/src/"],
      "@chaomingd/hooks": ["./packages/hooks/src/"],
      "@chaomingd/utils": ["./packages/utils/src/"],
      "@chaomingd/store": ["./packages/store/src/"]
    }
  }
}
